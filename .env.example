# Deployment mode (secrets and toggles only — everything else is in config.json)
BOT_MODE=paper
DRY_RUN=true
LIVE_TRADING_ENABLED=false

# L1 authentication (wallet signature) — unchanged in v2
PRIVATE_KEY=
# Required for signature_type 1 or 2 live accounts
FUNDER_ADDRESS=

# L2 authentication (HMAC) — unchanged in v2
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Database (required for live trading with recovery)
DATABASE_URL=

# Polygon RPC (required for proxy-wallet approval in signature_type=2)
POLYGON_RPC_URL=

# Optional: builder code for builder attribution (v2 replaces HMAC builder-auth headers)
# Get from: https://polymarket.com/settings?tab=builder
# BUILDER_CODE=

# Config file path (default: config.json)
# CONFIG_PATH=config.json
